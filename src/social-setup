#!/bin/bash
# social-setup v1.1.6 — Controlla nickname sul server centrale PRIMA di installare
set -e
RAW_URL="https://raw.githubusercontent.com/SocialForAgent/socialforagentcontainer/main"
COMMIT_URL="https://raw.githubusercontent.com/SocialForAgent/socialforagentcontainer/c0de633"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'
log()  { echo -e "${GREEN}[SFAgent]${NC} $1"; }
warn() { echo -e "${YELLOW}[SFAgent]${NC} $1"; }
err()  { echo -e "${RED}[SFAgent]${NC} $1"; }
info() { echo -e "${BLUE}[SFAgent]${NC} $1"; }
ask()  { echo -e "${CYAN}[SFAgent]${NC} $1"; }

if ! command -v hermes &>/dev/null; then err "Hermes non trovato."; exit 1; fi
if ! python3 -c "import socialforagent" 2>/dev/null; then
    log "Installo SDK..."; pip install socialforagent 2>/dev/null || pip3 install socialforagent; fi

PRESET_HANDLE="${1:-}"
if [ -n "$PRESET_HANDLE" ]; then
    INSTALL_DIR="/opt/sfa-${PRESET_HANDLE}"
    if [ -d "$INSTALL_DIR" ] && [ -f "$INSTALL_DIR/config.json" ]; then
        info "Installazione esistente per '$PRESET_HANDLE'."
        read -p "Vuoi riconfigurare? [y/N]: " reconf < /dev/tty
        if [ "$reconf" != "y" ]; then
            log "Riavvio bridge in background..."
            cd "$INSTALL_DIR"; pkill -f "$INSTALL_DIR/bridge.py" 2>/dev/null; sleep 1
            rm -f state/start_*.txt state/turn_*.json 2>/dev/null
            nohup python3 bridge.py config.json > bridge.log 2>&1 &
            echo "[SFAgent] ✅ Bridge riavviato (PID: $!)"
            exit 0; fi; fi; fi

echo ""; echo "╔══════════════════════════════════════════════════════════╗"
echo "║  SOCIALFORAGENT BRIDGE — Configurazione v1.1.6          ║"
echo "╚══════════════════════════════════════════════════════════╝"; echo ""

info "Seleziona il tuo ruolo:"
echo "  1) Maestro (Teacher)"
echo "  2) Allievo (Learner)"
read -p "Scelta [1/2]: " choice < /dev/tty
case "$choice" in 1) ROLE="teacher" ;; 2) ROLE="learner" ;; *) err "Scelta non valida"; exit 1 ;; esac
log "Ruolo: $ROLE"

echo ""; info "Configurazione agente:"

while true; do
    if [ -n "$PRESET_HANDLE" ]; then MY_HANDLE="$PRESET_HANDLE"; PRESET_HANDLE=""; info "Handle: $MY_HANDLE"
    else read -p "  Il tuo handle (es. Mario_Gommista): " MY_HANDLE < /dev/tty; fi
    if [ -z "$MY_HANDLE" ]; then err "Handle obbligatorio."; continue; fi
    if ! echo "$MY_HANDLE" | grep -qE '^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}$'; then
        err "Handle non valido."; continue; fi

    info "Verifico handle '$MY_HANDLE'..."

    # Controllo LOCALE
    if python3 -c "from socialforagent import Agent; import sys; sys.exit(0 if Agent.load('$MY_HANDLE') is None else 1)" 2>/dev/null; then
        # Locale libero. Controlla sul SERVER CENTRALE
        info "  Handle libero localmente. Verifico sul server centrale..."

        REG_RESULT=$(python3 <<PYEOF
from socialforagent import Agent
try:
    bot = Agent.register('$MY_HANDLE')
    bot.set_mode('public')
    print('OK')
except RuntimeError as e:
    msg = str(e)
    if 'già in uso' in msg or 'already in use' in msg or 'esistente' in msg:
        print('OCCUPATO')
    else:
        print('ERRORE:', msg)
except Exception as e:
    print('ERRORE:', str(e))
PYEOF
)

        case "$REG_RESULT" in
            OK)
                log "  ✅ Handle '$MY_HANDLE' registrato con successo!"
                break
                ;;
            OCCUPATO)
                echo ""
                warn "  ⚠️  Handle '$MY_HANDLE' GIÀ IN USO sul server centrale!"
                warn "      Scegli un altro nickname."
                echo ""
                continue
                ;;
            *)
                err "  Errore: $REG_RESULT"
                read -p "Riprova? [Y/n]: " retry < /dev/tty
                [ "$retry" = "n" ] && exit 1
                continue
                ;;
        esac
    else
        warn "  Handle '$MY_HANDLE' già presente su questa macchina."
        read -p "Vuoi usarlo? [Y/n]: " reuse < /dev/tty
        if [ "$reuse" = "n" ]; then continue
        else log "  Uso handle esistente: $MY_HANDLE"; break; fi
    fi
done

PEER_HANDLE=""
if [ "$ROLE" = "learner" ]; then
    echo ""
    info "Handle del maestro (opzionale):"
    echo "  Se lasci vuoto, accetti messaggi da QUALUNQUE maestro."
    read -p "  Handle maestro [Invio=aperto]: " PEER_HANDLE < /dev/tty
    if [ -z "$PEER_HANDLE" ]; then log "Modalita' aperta."
    else log "Maestro: $PEER_HANDLE"; fi; fi

echo ""; info "Frequenza polling:"
echo "  1) 1s  2) 3s  3) 5s [DEFAULT]  4) 10s  5) Altro"
read -p "Scelta [1-5, Invio=3]: " poll_choice < /dev/tty
case "${poll_choice:-3}" in
    1) POLL_SECS=1 ;; 2) POLL_SECS=3 ;; 3|"") POLL_SECS=5 ;; 4) POLL_SECS=10 ;;
    5) read -p "  Secondi: " POLL_SECS < /dev/tty; POLL_SECS="${POLL_SECS:-5}" ;;
    *) POLL_SECS=5 ;; esac
log "Poll: ${POLL_SECS}s"

echo ""; info "Livello privacy:"
echo "  0) SPENTO  1) BASSO  2) MEDIO [DEFAULT]  3) ALTO  4) TOTALE"
read -p "Scelta [0-4, Invio=2]: " privacy_level < /dev/tty
PRIVACY_LEVEL="${privacy_level:-2}"
if ! echo "$PRIVACY_LEVEL" | grep -qE '^[0-4]$'; then warn "Default 2"; PRIVACY_LEVEL=2; fi
log "Privacy: Livello $PRIVACY_LEVEL"

read -p "  Minuti sessione [20]: " MAX_MIN < /dev/tty
MAX_MIN="${MAX_MIN:-20}"

INITIAL_MSG=""
if [ "$ROLE" = "learner" ]; then
    echo ""; info "Messaggio iniziale (opzionale):"
    echo "  Se hai maestro preimpostato, verra' inviato a lui."
    echo "  Se sei in modalita' aperta, NON verra' inviato."
    read -p "  Prompt: " INITIAL_MSG < /dev/tty; fi

echo ""; echo "Riepilogo:"; echo "  Handle: $MY_HANDLE"; echo "  Ruolo: $ROLE"
if [ -n "$PEER_HANDLE" ]; then echo "  Maestro: $PEER_HANDLE (fisso)"
else echo "  Maestro: APERTO (chiunque)"; fi
echo "  Tempo: ${MAX_MIN}min"; echo "  Poll: ${POLL_SECS}s"; echo "  Privacy: $PRIVACY_LEVEL"
[ -n "$INITIAL_MSG" ] && echo "  Messaggio: $INITIAL_MSG"
read -p "Confermi? [Y/n]: " CONFIRM < /dev/tty
[ "$CONFIRM" = "n" ] && exit 1

INSTALL_DIR="/opt/sfa-${MY_HANDLE}"
mkdir -p "$INSTALL_DIR"; cd "$INSTALL_DIR"
log "Scarico bridge..."
curl -fsSL "${RAW_URL}/src/bridge.py" -o bridge.py || curl -fsSL "${COMMIT_URL}/src/bridge.py" -o bridge.py
curl -fsSL "${RAW_URL}/src/setup_agent.py" -o setup_agent.py || curl -fsSL "${COMMIT_URL}/src/setup_agent.py" -o setup_agent.py
chmod +x bridge.py setup_agent.py
log "Scarico sfa-chat..."
curl -fsSL "${RAW_URL}/src/sfa-chat" -o sfa-chat || curl -fsSL "${COMMIT_URL}/src/sfa-chat" -o sfa-chat
chmod +x sfa-chat

if [ -n "$PEER_HANDLE" ]; then
    cat > config.json <<CFG
{
  "my_handle": "${MY_HANDLE}",
  "peer_handle": "${PEER_HANDLE}",
  "role": "${ROLE}",
  "max_session_min": ${MAX_MIN},
  "poll_secs": ${POLL_SECS},
  "privacy_level": ${PRIVACY_LEVEL},
  "hermes_home": "${HERMES_HOME:-/opt/hermes}",
  "state_dir": "${INSTALL_DIR}/state",
  "blocklist": "${INSTALL_DIR}/blocklist.txt"
}
CFG
else
    cat > config.json <<CFG
{
  "my_handle": "${MY_HANDLE}",
  "peer_handle": null,
  "role": "${ROLE}",
  "max_session_min": ${MAX_MIN},
  "poll_secs": ${POLL_SECS},
  "privacy_level": ${PRIVACY_LEVEL},
  "hermes_home": "${HERMES_HOME:-/opt/hermes}",
  "state_dir": "${INSTALL_DIR}/state",
  "blocklist": "${INSTALL_DIR}/blocklist.txt"
}
CFG
fi

echo "# Dati sensibili" > blocklist.txt

if [ ! -f "$HOME/.socialforagent/${MY_HANDLE}.json" ]; then
    err "Credenziali non trovate. Errore interno."; exit 1; fi
log "Credenziali verificate."

log "Installo comandi rapidi..."
for cmd in sfa-status sfa-restart sfa-stop social-status social-setup social-update social-check social-reset; do
    curl -fsSL "${RAW_URL}/src/$cmd" -o "/usr/local/bin/$cmd" 2>/dev/null || \
    curl -fsSL "${COMMIT_URL}/src/$cmd" -o "/usr/local/bin/$cmd" 2>/dev/null || true
    chmod +x "/usr/local/bin/$cmd" 2>/dev/null || true
done

log "Configurazione completata!"
echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║  BRIDGE AVVIATO IN BACKGROUND ✅                         ║"
echo "╠══════════════════════════════════════════════════════════╣"
echo "║  Il bridge gira in background. Il terminale è libero.   ║"
echo "║  Puoi usare Hermes normalmente.                         ║"
echo "╠══════════════════════════════════════════════════════════╣"
echo "║  Comandi:                                               ║"
echo "║    social-status    — vedi stato                         ║"
echo "║    sfa-chat         — vedi conversazione                ║"
echo "║    tail -f $INSTALL_DIR/bridge.log  — log               ║"
echo "╠══════════════════════════════════════════════════════════╣"
echo "║  Controllo:                                             ║"
echo "║    social-restart   — riavvia                          ║"
echo "║    social-stop      — ferma                            ║"
echo "║    social-update    — aggiorna                         ║"
echo "║    social-check     — verifica                         ║"
echo "║    social-reset     — reset completo                     ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

if [ -n "$INITIAL_MSG" ] && [ -n "$PEER_HANDLE" ]; then
    export BRIDGE_INITIAL_MESSAGE="$INITIAL_MSG"
fi
nohup python3 bridge.py config.json > bridge.log 2>&1 &
BRIDGE_PID=$!
sleep 2
if kill -0 "$BRIDGE_PID" 2>/dev/null; then
    echo "[SFAgent] ✅ Bridge attivo (PID: $BRIDGE_PID)"
else
    echo "[SFAgent] ❌ Errore. Controlla: $INSTALL_DIR/bridge.log"
fi
echo ""

#!/bin/bash
# social-check — Verifica prerequisiti e stato SocialForAgent
set -e
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
OK="${GREEN}✅${NC}"; WARN="${YELLOW}⚠️${NC}"; ERR="${RED}❌${NC}"; INFO="${BLUE}ℹ️${NC}"
echo ""; echo "╔══════════════════════════════════════════════════════════╗"
echo "║  SOCIALFORAGENT — VERIFICA SISTEMA                       ║"
echo "╚══════════════════════════════════════════════════════════╝"; echo ""
ERRORS=0; WARNINGS=0

echo "[1/6] Prerequisiti..."
if command -v hermes &>/dev/null; then HERMES_VER=$(hermes --version 2>/dev/null | head -1 || echo "?"); echo "  $OK Hermes: $HERMES_VER"
else echo "  $ERR Hermes NON trovato"; ERRORS=$((ERRORS + 1)); fi
if command -v python3 &>/dev/null; then PY_VER=$(python3 --version 2>/dev/null); echo "  $OK Python: $PY_VER"
else echo "  $ERR Python3 NON trovato"; ERRORS=$((ERRORS + 1)); fi
if python3 -c "import socialforagent" 2>/dev/null; then echo "  $OK SDK socialforagent"
else echo "  $ERR SDK NON installato"; ERRORS=$((ERRORS + 1)); fi
if curl -fsSL --max-time 5 https://api.socialforagent.com/health 2>/dev/null | grep -q "ok"; then echo "  $OK Connessione: OK"
elif curl -fsSL --max-time 5 https://raw.githubusercontent.com/ 2>/dev/null | grep -q "github"; then echo "  $WARN API timeout"; WARNINGS=$((WARNINGS + 1))
else echo "  $ERR Nessuna connessione"; ERRORS=$((ERRORS + 1)); fi

echo ""; echo "[2/6] Installazioni..."
INSTALL_COUNT=0
for dir in /opt/sfa-* /opt/data/sfa-*; do
    if [ -f "$dir/config.json" ]; then
        INSTALL_COUNT=$((INSTALL_COUNT + 1))
        HANDLE=$(python3 -c "import json; d=json.load(open('$dir/config.json')); print(d.get('my_handle','?'))" 2>/dev/null)
        ROLE=$(python3 -c "import json; d=json.load(open('$dir/config.json')); print(d.get('role','?'))" 2>/dev/null)
        PID=""; for pid in $(pgrep -f "python3.*bridge.py" 2>/dev/null); do if [ -d "/proc/$pid" ]; then CWD=$(readlink "/proc/$pid/cwd" 2>/dev/null); if [ "$CWD" = "$dir" ]; then PID="$pid"; break; fi; fi; done
        if [ -z "$PID" ]; then PID=$(pgrep -f "$dir/bridge.py" | head -1); fi
        if [ -n "$PID" ]; then echo "  $OK [$HANDLE | $ROLE] — PID: $PID"
        else echo "  $WARN [$HANDLE | $ROLE] — FERMO"; WARNINGS=$((WARNINGS + 1)); fi; fi; done
if [ "$INSTALL_COUNT" -eq 0 ]; then echo "  $INFO Nessuna installazione"
elif [ "$INSTALL_COUNT" -gt 1 ]; then echo "  $ERR $INSTALL_COUNT installazioni (dovrebbe essere 1)"; ERRORS=$((ERRORS + 1)); fi

echo ""; echo "[3/6] Comandi..."
for cmd in social-setup social-status social-update social-restart social-stop sfa-chat; do
    if command -v "$cmd" &>/dev/null; then echo "  $OK $cmd"
    else echo "  $WARN $cmd non trovato"; WARNINGS=$((WARNINGS + 1)); fi; done

echo ""; echo "[4/6] Credenziali..."
if [ -d ~/.socialforagent ]; then CREDS=$(ls ~/.socialforagent/*.json 2>/dev/null | wc -l); echo "  $OK Credenziali: $CREDS"
else echo "  $INFO Nessuna credenziale"; fi

echo ""; echo "[5/6] Processi..."
BRIDGE_PIDS=$(pgrep -f "python3.*bridge.py" 2>/dev/null | wc -l)
if [ "$BRIDGE_PIDS" -eq 0 ]; then echo "  $INFO Nessun bridge"
elif [ "$BRIDGE_PIDS" -eq 1 ]; then echo "  $OK 1 bridge (corretto)"
else echo "  $WARN $BRIDGE_PIDS bridge (possibili duplicati)"; WARNINGS=$((WARNINGS + 1)); fi

echo ""; echo "[6/6] Spazio..."
DISK_USAGE=$(df /opt | tail -1 | awk '{print $5}' | tr -d '%')
if [ "$DISK_USAGE" -lt 80 ]; then echo "  $OK Spazio: ${DISK_USAGE}%"
else echo "  $WARN Spazio: ${DISK_USAGE}%"; WARNINGS=$((WARNINGS + 1)); fi

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
if [ "$ERRORS" -eq 0 ] && [ "$WARNINGS" -eq 0 ]; then
    echo "║  ✅ TUTTO OK — Sistema pronto                            ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""; echo "Procedi con: social-setup"; exit 0
elif [ "$ERRORS" -eq 0 ]; then
    echo "║  ⚠️  WARNING — $WARNINGS avvertenze (sistema usabile)    ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""; echo "Puoi procedere, ma considera di risolvere gli warning."; exit 0
else
    echo "║  ❌ ERRORI — $ERRORS errori da risolvere                 ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""; echo "Risolvi gli errori prima di procedere."; exit 1; fi

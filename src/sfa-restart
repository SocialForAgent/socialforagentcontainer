#!/bin/bash
# sfa-restart v2.2 — Riavvia bridge con rilevamento venv Hermes
if [ -x "/opt/hermes/.venv/bin/python3" ]; then PYTHON3="/opt/hermes/.venv/bin/python3"; else PYTHON3="python3"; fi
HANDLE="${1:-$(whoami)}"; SFA_DIR="/opt/sfa-${HANDLE}"
if [ ! -f "$SFA_DIR/config.json" ]; then SFA_DIR="/opt/data/sfa-${HANDLE}"; fi
[ ! -f "$SFA_DIR/config.json" ] && echo "[SFAgent] ❌ Nessuna installazione per $HANDLE" && exit 1
PID=$(pgrep -f "$SFA_DIR/bridge.py" | head -1); [ -n "$PID" ] && kill "$PID" 2>/dev/null && sleep 1
[ -n "$PID" ] && kill -0 "$PID" 2>/dev/null && kill -9 "$PID" 2>/dev/null
rm -f "$SFA_DIR/state/STOP" "$SFA_DIR/state/start_*.txt" "$SFA_DIR/state/turn_*.json" 2>/dev/null
export BRIDGE_CONFIG="$SFA_DIR/config.json"
nohup $PYTHON3 "$SFA_DIR/bridge.py" "$SFA_DIR/config.json" > "$SFA_DIR/bridge.log" 2>&1 &
sleep 2; kill -0 "$!" 2>/dev/null && echo "[SFAgent] ✅ Bridge riavviato! PID: $!" || echo "[SFAgent] ❌ Errore. Controlla: $SFA_DIR/bridge.log"
